{
  "name": "lyra-ai-platform",
  "version": "1.0.0",
  "description": "Lyra AI - Multi-perspective orchestrator with specialized agents",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "// ============================================================": "",
    "// MAIN LAUNCHERS (run_all.py)": "",
    "// ============================================================": "",
    
    "dev": "python run_all.py",
    "dev:quick": "python run_all.py --skip-check",
    "start": "python run_all.py",
    "start:all": "python run_all.py",
    
    "// ============================================================": "",
    "// COMPONENT-SPECIFIC (run_all.py)": "",
    "// ============================================================": "",
    
    "dev:web-api": "python run_all.py --components web api",
    "dev:agents-only": "python run_all.py --components gateway lyra",
    "dev:web-only": "python run_all.py --components web",
    "dev:api-only": "python run_all.py --components api",
    
    "// ============================================================": "",
    "// LEGACY/MANUAL LAUNCHERS": "",
    "// ============================================================": "",
    
    "dev:manual": "npm --workspace apps/companion_api run dev & npm --workspace apps/companion_web run dev",
    "dev:api": "npm --workspace apps/companion_api run dev",
    "dev:web": "npm --workspace apps/companion_web run dev",
    "dev:agents": "python lyra_app/app.py",
    "dev:gateway": "python api_gateway.py",
    "dev:lyra": "python -m lyra_core.lyra_ai",
    
    "dev:all": "concurrently -n \"API,WEB,AGENTS,GATEWAY\" -c \"cyan,magenta,yellow,green\" \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:agents\" \"npm run dev:gateway\"",
    "dev:full": "concurrently -n \"WEB,LYRA\" -c \"magenta,yellow\" \"npm run dev:manual\" \"npm run dev:lyra\"",
    
    "// ============================================================": "",
    "// AGENT MANAGEMENT": "",
    "// ============================================================": "",
    
    "agents:start": "python scripts/start_agents.py",
    "agents:stop": "python scripts/stop_agents.py",
    "agents:status": "python scripts/agent_status.py",
    "agents:test": "python scripts/test_agents.py",
    "agents:test:all": "python scripts/test_all_agents.py",
    "agents:test:frontend": "python scripts/test_frontend_agent.py",
    "agents:test:legal": "python scripts/test_legal_agent.py",
    "agents:test:medical": "python scripts/test_medical_agent.py",
    "agents:test:concierge": "python scripts/test_concierge_agent.py",
    
    "// ============================================================": "",
    "// CONFIGURATION": "",
    "// ============================================================": "",
    
    "config:validate": "python scripts/test_config.py",
    "config:show": "python -c \"from lyra_app.config import print_config_summary; print_config_summary()\"",
    "config:init": "python scripts/init_config.py",
    "config:check": "python scripts/check_config.py",
    
    "// ============================================================": "",
    "// PYTHON SETUP": "",
    "// ============================================================": "",
    
    "py:install": "bash scripts/install.sh",
    "py:install:dev": "bash scripts/install.sh dev",
    "py:install:prod": "bash scripts/install.sh prod",
    "py:verify": "python scripts/verify_install.py",
    "py:update": "pip install --upgrade -r requirements.txt",
    "py:freeze": "pip freeze > requirements-lock.txt",
    
    "// ============================================================": "",
    "// TESTING": "",
    "// ============================================================": "",
    
    "test": "npm run test:agents && npm run test:web && npm run test:api",
    "test:agents": "pytest tests/agents -v",
    "test:web": "npm --workspace apps/companion_web run test",
    "test:api": "npm --workspace apps/companion_api run test",
    "test:integration": "pytest tests/integration -v",
    "test:e2e": "playwright test",
    "test:watch": "pytest tests --watch",
    "test:coverage": "pytest --cov=lyra_core --cov=agents --cov-report=html",
    
    "// ============================================================": "",
    "// LINTING & FORMATTING": "",
    "// ============================================================": "",
    
    "lint": "npm run lint:js && npm run lint:python",
    "lint:js": "eslint \"apps/**/*.{js,jsx,ts,tsx}\"",
    "lint:python": "flake8 lyra_core agents scripts",
    "lint:fix": "npm run lint:js -- --fix && npm run format:python",
    
    "format": "npm run format:js && npm run format:python",
    "format:js": "prettier --write \"apps/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:python": "black lyra_core agents scripts",
    "format:check": "prettier --check \"apps/**/*.{js,jsx,ts,tsx,json,css,md}\" && black --check lyra_core agents scripts",
    
    "typecheck": "tsc --noEmit",
    
    "// ============================================================": "",
    "// BUILD & DEPLOYMENT": "",
    "// ============================================================": "",
    
    "check:pages": "node scripts/check-pages-default-export.mjs apps/companion_web/pages",
    "build": "npm run check:pages && npm run build:web && npm run build:api",
    "build:web": "npm --workspace apps/companion_web run build",
    "build:api": "npm --workspace apps/companion_api run build",
    "build:docker": "docker-compose build",
    "build:all": "npm run build && docker-compose build",
    
    "// ============================================================": "",
    "// PRODUCTION": "",
    "// ============================================================": "",
    
    "start:prod": "python run_all.py",
    "start:production": "concurrently -n \"API,WEB,AGENTS\" -c \"cyan,magenta,yellow\" \"npm run start:api\" \"npm run start:web\" \"npm run start:agents\"",
    "start:web": "npm --workspace apps/companion_web run start",
    "start:api": "npm --workspace apps/companion_api run start",
    "start:agents": "python lyra_app/app.py --production",
    "start:gateway": "gunicorn -w 4 -b 0.0.0.0:8000 api_gateway:app",
    
    "// ============================================================": "",
    "// DATABASE": "",
    "// ============================================================": "",
    
    "db:migrate": "python scripts/migrate_db.py",
    "db:seed": "python scripts/seed_db.py",
    "db:reset": "python scripts/reset_db.py",
    "db:backup": "python scripts/backup_db.py",
    "db:restore": "python scripts/restore_db.py",
    
    "// ============================================================": "",
    "// UTILITIES": "",
    "// ============================================================": "",
    
    "clean": "npm run clean:deps && npm run clean:build && npm run clean:cache",
    "clean:deps": "rm -rf node_modules apps/*/node_modules",
    "clean:build": "rm -rf apps/*/.next apps/*/dist apps/*/build",
    "clean:cache": "rm -rf .pytest_cache __pycache__ */__pycache__ */*/__pycache__",
    "clean:logs": "rm -rf logs/*.log",
    "clean:all": "npm run clean && npm run clean:logs",
    
    "setup": "npm install && pip install -r requirements.txt && npm run config:init",
    "setup:dev": "npm install && pip install -r requirements-dev.txt && npm run config:init",
    "setup:full": "npm run py:install:dev && npm install && npm run config:init",
    "setup:quick": "npm install && npm run config:init",
    
    "logs": "tail -f logs/lyra.log",
    "logs:agents": "tail -f logs/agents.log",
    "logs:security": "tail -f logs/security.log",
    "logs:all": "tail -f logs/*.log",
    
    "// ============================================================": "",
    "// MONITORING & HEALTH": "",
    "// ============================================================": "",
    
    "health": "python scripts/health_check.py",
    "health:watch": "watch -n 5 python scripts/health_check.py",
    "monitor": "python scripts/monitor_system.py",
    "stats": "python scripts/system_stats.py",
    
    "// ============================================================": "",
    "// DOCUMENTATION": "",
    "// ============================================================": "",
    
    "docs": "npm run docs:generate && npm run docs:serve",
    "docs:generate": "python scripts/generate_docs.py",
    "docs:serve": "docsify serve docs",
    "docs:api": "python scripts/generate_api_docs.py",
    "docs:build": "npm run docs:generate && docsify build docs",
    
    "// ============================================================": "",
    "// SHORTCUTS & ALIASES": "",
    "// ============================================================": "",
    
    "d": "npm run dev",
    "s": "npm run start",
    "t": "npm run test",
    "b": "npm run build",
    "c": "npm run clean"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.4",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "@playwright/test": "^1.40.1",
    "docsify-cli": "^4.4.4"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0",
    "python": ">=3.9.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/lyra-ai-platform.git"
  },
  "keywords": [
    "ai",
    "agents",
    "orchestrator",
    "multi-perspective",
    "lyra"
  ],
  "author": "Ricky",
  "license": "MIT"
}
